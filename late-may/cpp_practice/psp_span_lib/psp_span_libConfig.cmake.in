# psp_span_libConfig.cmake.in — template that CMakePackageConfigHelpers
# fills in at configure time. After configure_package_config_file()
# runs (in CMakeLists.txt), every @PACKAGE_*@ and @INSTALL_*@ token
# is replaced with the real install-tree path.
#
# This file is what `find_package(psp_span_lib REQUIRED)` triggers
# from a consumer. The standard pattern is: just include the targets
# file generated by install(EXPORT ...). That's it.
#
# Consumers then write:
#     find_package(psp_span_lib REQUIRED)
#     target_link_libraries(myapp PRIVATE psp_span_lib::psp_span_lib)
# and the imported target brings the include path and compile
# features with it.

@PACKAGE_INIT@

include(CMakeFindDependencyMacro)
# No external dependencies today. If psp_span_lib ever starts to
# depend on, say, fmt, this is where the find_dependency(fmt) call
# would go. Leaving the include in to show the standard pattern.

include("${CMAKE_CURRENT_LIST_DIR}/psp_span_libTargets.cmake")

# A small courtesy: print a status line so a consumer's configure
# output is informative.
#
# Variable notes (these tripped me up on first cut — documenting here):
#   - ${psp_span_lib_VERSION} is set automatically by find_package()
#     to the version it resolved against (from the ConfigVersion file).
#     *Not* ${PACKAGE_VERSION} — that name isn't a thing.
#   - ${PACKAGE_PREFIX_DIR} IS set by the @PACKAGE_INIT@ block above
#     (the get_filename_component() call near the top of this file).
#     It points at the install prefix, which is what consumers want.
#   - ${PACKAGE_PREFIX_PATH} is NOT a CMake variable. I used it on
#     first cut and got empty parens in the status output.
if(NOT psp_span_lib_FIND_QUIETLY)
    message(STATUS "Found psp_span_lib: ${psp_span_lib_VERSION} (installed at ${PACKAGE_PREFIX_DIR})")
endif()